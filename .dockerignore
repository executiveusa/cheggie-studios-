# =============================================================================
# Cheggie Studios — .dockerignore
# Excludes files that should not be sent to the Docker build context.
# Keeps the build context lean and prevents secrets from leaking into images.
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies (reinstalled during build)
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/

# -----------------------------------------------------------------------------
# Next.js build output (rebuilt inside container)
# -----------------------------------------------------------------------------
.next/
out/
dist/
build/

# -----------------------------------------------------------------------------
# Environment files — secrets must be injected at runtime, not baked in
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging
# Keep the example for documentation purposes
# !.env.example

# -----------------------------------------------------------------------------
# Local dev uploads (not part of the app image — use object storage in prod)
# -----------------------------------------------------------------------------
uploads/

# -----------------------------------------------------------------------------
# Git history
# -----------------------------------------------------------------------------
.git/
.gitignore

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# -----------------------------------------------------------------------------
# Testing artifacts (not needed in production image)
# -----------------------------------------------------------------------------
coverage/
playwright-report/
test-results/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
__tests__/
__mocks__/

# -----------------------------------------------------------------------------
# TypeScript build info
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Documentation (not needed in runtime image)
# -----------------------------------------------------------------------------
*.md
docs/

# -----------------------------------------------------------------------------
# Turbo / Monorepo
# -----------------------------------------------------------------------------
.turbo/

# -----------------------------------------------------------------------------
# Sentry local config
# -----------------------------------------------------------------------------
.sentryclirc

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.vercel/
.netlify/
storybook-static/
docker-data/
