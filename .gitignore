# =============================================================================
# Cheggie Studios — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Next.js build output
# -----------------------------------------------------------------------------
.next/
out/
dist/
build/

# -----------------------------------------------------------------------------
# Environment files — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.staging
# Allow the example file
!.env.example

# -----------------------------------------------------------------------------
# Local uploads (dev storage adapter)
# -----------------------------------------------------------------------------
uploads/
/public/uploads/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log.*

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.history/

# -----------------------------------------------------------------------------
# TypeScript / Build caches
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Prisma
# -----------------------------------------------------------------------------
# Allow migrations — these should be committed
# prisma/migrations/

# Generated Prisma client (regenerated on install via postinstall)
prisma/.prisma/
# Old generated location
node_modules/.prisma/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/

# -----------------------------------------------------------------------------
# Turbo / Monorepo tooling
# -----------------------------------------------------------------------------
.turbo/
.cache/

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
.sentryclirc
# Sentry source maps (uploaded during build, not needed in repo)
.sentry/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Allow Dockerfile and docker-compose files
# Ignore any local docker volumes
docker-data/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
*.p12
*.pfx
.vercel/
.netlify/
# Storybook build
storybook-static/
