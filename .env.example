# =============================================================================
# Cheggie Studios — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cheggie_studios
# Optional: separate read replica for analytics queries
# DATABASE_URL_READ=postgresql://postgres:postgres@localhost:5432/cheggie_studios

# -----------------------------------------------------------------------------
# Redis (BullMQ queues + session caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
# Optional: Redis with auth
# REDIS_URL=redis://:your-password@localhost:6379
# Optional: Upstash Redis (serverless)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Storage
# Use STORAGE_ADAPTER=local for development, s3 for production.
# Any S3-compatible provider works: AWS S3, Cloudflare R2, MinIO, Backblaze B2.
# -----------------------------------------------------------------------------
STORAGE_ADAPTER=local
LOCAL_STORAGE_PATH=./uploads

# S3-compatible (set these when STORAGE_ADAPTER=s3)
S3_BUCKET=cheggie-studios
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Leave blank for AWS S3; set for R2/MinIO/custom endpoint
S3_ENDPOINT=
# Public base URL for CDN/pre-signed URL generation
S3_PUBLIC_URL=

# Upload limits
MAX_UPLOAD_SIZE_MB=500

# -----------------------------------------------------------------------------
# AI / Transcription (Whisper)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Self-hosted Whisper API (faster-whisper / whisper.cpp compatible)
WHISPER_API_URL=http://localhost:8000
WHISPER_MODEL=large-v3
# Timeout for transcription requests (ms)
WHISPER_TIMEOUT_MS=300000

# -----------------------------------------------------------------------------
# OAuth Providers (NextAuth.js v5)
# -----------------------------------------------------------------------------
# Google OAuth — https://console.cloud.google.com/
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth — https://github.com/settings/applications/new
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# -----------------------------------------------------------------------------
# Sentry (Error monitoring)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=cheggie-studios
SENTRY_PROJECT=cheggie-studios
# Set to true to suppress Sentry logs during CI builds
SENTRY_SILENT=false

# -----------------------------------------------------------------------------
# Email (Transactional — Nodemailer)
# Supports any SMTP server: Resend, Postmark, SES, Mailgun, etc.
# For Resend: SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_USER=resend
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cheggiestudios.com
EMAIL_REPLY_TO=support@cheggiestudios.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# ComfyUI (AI avatar / thumbnail generation — future feature)
# -----------------------------------------------------------------------------
COMFYUI_URL=http://localhost:8188
COMFYUI_ENABLED=false
COMFYUI_API_KEY=

# -----------------------------------------------------------------------------
# BullMQ / Queue configuration
# -----------------------------------------------------------------------------
QUEUE_CONCURRENCY_TRANSCRIPT=2
QUEUE_CONCURRENCY_SUBTITLE=4
QUEUE_CONCURRENCY_EXPORT=2
QUEUE_CONCURRENCY_SEARCH=4
# Job retention: how long to keep completed/failed jobs (ms)
QUEUE_RETENTION_COMPLETED_MS=86400000
QUEUE_RETENTION_FAILED_MS=604800000

# -----------------------------------------------------------------------------
# Public app config (exposed to client)
# Variables prefixed with NEXT_PUBLIC_ are bundled into the client.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Cheggie Studios
NEXT_PUBLIC_APP_DESCRIPTION=Serbian-first AI video editing and content workflow platform
# Feature flags
NEXT_PUBLIC_FEATURE_COMFYUI=false
NEXT_PUBLIC_FEATURE_COLLABORATION=false
NEXT_PUBLIC_FEATURE_ANALYTICS=false

# -----------------------------------------------------------------------------
# Docker build (set to "true" in Dockerfile to enable standalone output)
# -----------------------------------------------------------------------------
DOCKER_BUILD=false
